<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{meta_title}}</title>

    <link rel="stylesheet" href="{{asset "css/fonts.css"}}">
    <link rel="stylesheet" href="{{asset "css/variables.css"}}">
    <link rel="stylesheet" href="{{asset "css/screen.css"}}">

    {{ghost_head}}

    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "Cooperation Tulsa",
        "url": "{{@site.url}}",
        {{#if @site.logo}}"logo": "{{@site.url}}{{@site.logo}}",{{/if}}
        "description": "Building community power through gardens, popular education, mutual aid, and direct democracy in Tulsa, Oklahoma.",
        "address": {
            "@type": "PostalAddress",
            "addressLocality": "Tulsa",
            "addressRegion": "OK",
            "addressCountry": "US"
        },
        "sameAs": [
            {{#if @custom.instagram_url}}"{{@custom.instagram_url}}"{{/if}}
            {{#if @custom.facebook_url}},"{{@custom.facebook_url}}"{{/if}}
            {{#if @custom.twitter_url}},"{{@custom.twitter_url}}"{{/if}}
        ]
    }
    </script>
</head>
<body class="{{body_class}}">
    <div class="site-wrapper">
        {{> header}}

        <main class="site-main">
            {{{body}}}
        </main>

        {{> footer}}
    </div>

    <script src="{{asset "js/main.js"}}"></script>
    <script defer src="https://analytics.cooperationtulsa.org/script.js" data-website-id="6e92ca8e-33c5-4255-83e3-3261ad80c48c"></script>
    {{ghost_foot}}
</body>
</html>
