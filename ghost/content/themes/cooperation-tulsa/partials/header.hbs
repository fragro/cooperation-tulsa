<header class="site-header">
    <div class="header-inner container">
        <a class="site-logo" href="{{@site.url}}">
            {{#if @site.logo}}
                <img src="{{@site.logo}}" alt="{{@site.title}}">
            {{else}}
                <span class="site-title">{{@site.title}}</span>
            {{/if}}
        </a>

        <button class="nav-toggle" aria-expanded="false" aria-label="Toggle navigation">
            <span class="nav-toggle-bar"></span>
            <span class="nav-toggle-bar"></span>
            <span class="nav-toggle-bar"></span>
        </button>

        <nav class="nav-menu" role="navigation">
            {{navigation}}
            <ul class="nav">
                <li><a href="/events/">Events</a></li>
                <li><a href="/gallery/">Gallery</a></li>
            </ul>
            <button class="nav-search" data-ghost-search aria-label="Search">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            </button>
            <a href="{{@custom.donation_url}}" class="btn btn-wheat nav-donate" target="_blank" rel="noopener">Donate</a>
        </nav>
    </div>
</header>
