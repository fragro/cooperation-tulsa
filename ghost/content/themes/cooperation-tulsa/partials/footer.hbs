<footer class="site-footer">
    <div class="footer-inner container">
        {{!-- Top: Logo + tagline + newsletter --}}
        <div class="footer-top">
            <div class="footer-brand">
                {{#if @site.logo}}
                    <img src="{{@site.logo}}" alt="{{@site.title}}" class="footer-logo">
                {{/if}}
                <p class="footer-tagline">Revolution from the ground up, without rulers.</p>
            </div>
            <div class="footer-subscribe">
                <h3 class="footer-heading">Stay in the loop</h3>
                <p>Get updates on events, volunteer days, and community news.</p>
                {{> newsletter-form}}
            </div>
        </div>

        {{!-- Middle: Nav columns --}}
        <div class="footer-columns">
            <div class="footer-col">
                <h4 class="footer-heading">Explore</h4>
                <ul class="footer-links">
                    <li><a href="/">Home</a></li>
                    <li><a href="/gallery/">Gallery</a></li>
                    <li><a href="/events/">Events</a></li>
                    <li><a href="/resources/">Resources</a></li>
                </ul>
            </div>
            <div class="footer-col">
                <h4 class="footer-heading">Get Involved</h4>
                <ul class="footer-links">
                    <li><a href="{{@custom.donation_url}}" target="_blank" rel="noopener">Donate</a></li>
                    <li><a href="/donate/">How to Help</a></li>
                </ul>
            </div>
            <div class="footer-col">
                <h4 class="footer-heading">Connect</h4>
                <ul class="footer-links">
                    {{#if @custom.instagram_url}}
                        <li><a href="{{@custom.instagram_url}}" target="_blank" rel="noopener">Instagram</a></li>
                    {{/if}}
                    {{#if @custom.facebook_url}}
                        <li><a href="{{@custom.facebook_url}}" target="_blank" rel="noopener">Facebook</a></li>
                    {{/if}}
                    {{#if @custom.twitter_url}}
                        <li><a href="{{@custom.twitter_url}}" target="_blank" rel="noopener">Twitter</a></li>
                    {{/if}}
                    {{#if @custom.discord_url}}
                        <li><a href="{{@custom.discord_url}}" target="_blank" rel="noopener">Discord</a></li>
                    {{/if}}
                </ul>
            </div>
        </div>

        {{> bookchin-quote}}

        <div class="footer-bottom">
            <p>&copy; {{date format="YYYY"}} {{@site.title}}. Built with community power &amp; <a href="https://ghost.org" target="_blank" rel="noopener">Ghost</a>.</p>
        </div>
    </div>
</footer>
