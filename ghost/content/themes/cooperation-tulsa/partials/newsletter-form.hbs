<form class="newsletter-form" data-members-form="subscribe">
    <div class="form-group">
        <label class="sr-only">Email address</label>
        <input type="email" required placeholder="Your email address" data-members-email aria-label="Email address">
        <button type="submit">Subscribe</button>
    </div>
    <div class="newsletter-message" style="display:none;"></div>
    <p class="message-success" style="display:none; color: var(--color-cream); margin-top: var(--space-sm);">You're in! Check your email to confirm.</p>
    <p class="message-error" style="display:none; color: #ff6b6b; margin-top: var(--space-sm);">Something went wrong. Please try again.</p>
</form>
<script>
(function() {
    document.querySelectorAll('[data-members-form]').forEach(function(form) {
        form.addEventListener('submit', function() {
            var btn = form.querySelector('button');
            btn.textContent = 'Sending...';
            btn.disabled = true;
        });
        var observer = new MutationObserver(function() {
            var success = form.classList.contains('success');
            var error = form.classList.contains('error');
            var msgSuccess = form.querySelector('.message-success');
            var msgError = form.querySelector('.message-error');
            if (success && msgSuccess) {
                msgSuccess.style.display = 'block';
                form.querySelector('.form-group').style.display = 'none';
            }
            if (error && msgError) {
                msgError.style.display = 'block';
                var btn = form.querySelector('button');
                btn.textContent = 'Subscribe';
                btn.disabled = false;
            }
        });
        observer.observe(form, { attributes: true, attributeFilter: ['class'] });
    });
})();
</script>
